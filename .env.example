# ==========================================
# 0. PATHS DE OTROS REPOS (solo dev local)
# ==========================================
# Path al repo infra-keycloak. Usado por scripts/dev-up.sh para levantar
# Keycloak automáticamente si su network no existe. Relativo al directorio
# del backend (donde corre `docker compose`). Default: hermano del backend.
INFRA_KEYCLOAK_PATH=../infra-keycloak

# ==========================================
# 1. PERFIL Y COMPORTAMIENTO
# ==========================================
# Perfil de arranque: 'dev' (Para entorno de desarrollo) | 'prod' (Para producción)
APP_PROFILE=dev

# DB DDL: 'update' (Dev) | 'validate' (Prod)
DB_DDL_AUTO=update

# SQL Logs: 'true' (Dev) | 'false' (Prod)
DB_SHOW_SQL=true

# Logs App: 'DEBUG' (Dev) | 'INFO' (Prod)
LOG_LEVEL=DEBUG

# Renderizado: 'true' (Dev - cómodo) | 'false' (Prod - rápido)
OPEN_IN_VIEW=true

# ==========================================
# 2. CONECTIVIDAD
# ==========================================
# Local: http://localhost:3000 | Prod: https://midominio.com
FRONTEND_URL=http://localhost:3000

# ==========================================
# 3. INFRAESTRUCTURA
# ==========================================
POSTGRES_DB=mi_basedatos
PORT_DB=mi_puerto_db
PORT_BACKEND=mi_puerto_backend

# ==========================================
# 4. KEYCLOAK (externo — vive en repo cartones-app/infra-keycloak)
# ==========================================
# URLs del realm (REQUERIDAS en dev y prod; en el perfil 'local' se ignoran porque desactiva Keycloak).
# El backend NO levanta Keycloak — esperá que esté corriendo en la URL indicada.
#
# Dev típico (clonando cartones-app/infra-keycloak y levantándolo en localhost:8080):
#
# - ISSUER_URI: lo que dice el claim `iss` del JWT (Spring lo compara por string).
#   Como Keycloak corre con KC_HOSTNAME=localhost, el iss es localhost:8080.
# - JWK_SET_URI: la URL desde donde el backend BAJA las public keys. El backend
#   está en su propio docker network, pero se une a la red externa
#   `infra_keycloak_proxy_local` (ver compose), así puede resolver el container
#   `keycloak` por DNS interno sin pasar por el host. Si Keycloak corre fuera
#   de Docker, usar la URL pública en su lugar.
KEYCLOAK_ISSUER_URI=http://localhost:8080/realms/cartones
KEYCLOAK_JWK_SET_URI=http://keycloak:8080/realms/cartones/protocol/openid-connect/certs
# Prod típico:
# KEYCLOAK_ISSUER_URI=https://keycloak.midominio.com/realms/cartones
# KEYCLOAK_JWK_SET_URI=https://keycloak.midominio.com/realms/cartones/protocol/openid-connect/certs

# ==========================================
# 5. STORAGE DE ARCHIVOS
# ==========================================
# Directorio DENTRO del container donde el backend escribe los PDFs generados
# (etiquetas + resumen). Convención del proyecto: todo lo del runtime vive bajo
# /cartones — `/cartones/app.jar`, `/cartones/logs/`, `/cartones/storage/`.
APP_STORAGE_DIRECTORY=/cartones/storage

# Directorio del HOST que se monta como volumen en /cartones/storage del container.
# En VPS prod usar un path absoluto inspeccionable/backupeable con tools
# normales (ej. /opt/cartones/storage), no un named volume gestionado por
# Docker. En dev local lo pisa docker-compose.local.yml con `./storage`
# (relativo al repo) para que los archivos sean visibles directamente desde
# el editor.
#
# IMPORTANTE: el directorio debe existir en el host ANTES de `docker compose up`
# con permisos para el UID 1000 (usuario `spring` del container, ver Dockerfile).
# Sin esto, Docker crea el bind mount como root:root 0755 y el backend no puede
# escribir. En el VPS:
#   sudo mkdir -p /opt/cartones/storage && sudo chown 1000:1000 /opt/cartones/storage
HOST_STORAGE_DIR=/opt/cartones/storage

# ==========================================
# 6. UPLOADS (rate limit + multipart)
# ==========================================
# Requests por minuto por usuario (sub del JWT, fallback IP) en endpoints de upload.
# Default 10. 0 desactiva el limiter (NO recomendado).
# APP_UPLOADS_RATE_LIMIT_RPM=10

# Tamaño máximo por archivo / por request. Defaults razonables: 10MB / 11MB.
# APP_MULTIPART_MAX_FILE_SIZE=10MB
# APP_MULTIPART_MAX_REQUEST_SIZE=11MB
