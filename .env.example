# ==========================================
# 1. PERFIL Y COMPORTAMIENTO
# ==========================================
# Perfil de arranque: 'dev' (Para entorno de desarrollo) | 'prod' (Para producción)
APP_PROFILE=dev

# DB DDL: 'update' (Dev) | 'validate' (Prod)
DB_DDL_AUTO=update

# SQL Logs: 'true' (Dev) | 'false' (Prod)
DB_SHOW_SQL=true

# Logs App: 'DEBUG' (Dev) | 'INFO' (Prod)
LOG_LEVEL=DEBUG

# Renderizado: 'true' (Dev - cómodo) | 'false' (Prod - rápido)
OPEN_IN_VIEW=true

# ==========================================
# 2. CONECTIVIDAD
# ==========================================
# Local: http://localhost:3000 | Prod: https://midominio.com
FRONTEND_URL=http://localhost:3000

# ==========================================
# 3. INFRAESTRUCTURA
# ==========================================
POSTGRES_DB=mi_basedatos
PORT_DB=mi_puerto_db
PORT_BACKEND=mi_puerto_backend
PORT_KEYCLOAK=8080

# ==========================================
# 4. KEYCLOAK
# ==========================================
# Usuario administrador de Keycloak (panel /admin)
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=una_contrasena_segura

# URLs del realm (solo necesarias en prod — en dev se calculan automáticamente)
# KEYCLOAK_ISSUER_URI=https://keycloak.midominio.com/realms/cartones
# KEYCLOAK_JWK_SET_URI=https://keycloak.midominio.com/realms/cartones/protocol/openid-connect/certs

# ==========================================
# 5. UPLOADS (rate limit + multipart)
# ==========================================
# Requests por minuto por usuario (sub del JWT, fallback IP) en endpoints de upload.
# Default 10. 0 desactiva el limiter (NO recomendado).
# APP_UPLOADS_RATE_LIMIT_RPM=10